# ============================================================
#  SRP MediFlow — Environment Variables Template
#  Copy this file to .env and fill in your REAL values.
#  The .env file is NEVER committed to GitHub (it's gitignored).
#  See HETZNER_DEPLOY.md for full deployment instructions.
# ============================================================

# ── PostgreSQL Database Connection ──────────────────────────
# Hetzner Linux production: PG_PORT=5432
# Local Windows dev:        PG_PORT=5434
PG_HOST=localhost
PG_PORT=5432
PG_DB=hospital_ai
PG_USER=ats_user
PG_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ── Platform / SaaS layer database ──────────────────────────
PLATFORM_DB_NAME=srp_platform_db

# ── Web Server ───────────────────────────────────────────────
PORT=7500
HOSPITAL_NAME=SRP MediFlow
# Your real public domain (used in cookies, CORS, credentials doc)
APP_URL=https://mediflow.srpailabs.com
# Root domain for tenant routing (subdomains become tenant slugs)
ROOT_DOMAIN=mediflow.srpailabs.com

# ── Security ─────────────────────────────────────────────────
# Fallback admin password if no staff users exist (override on production)
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ── Ngrok (disabled by default on production) ────────────────
# Set to 1 only on local dev if you want ngrok tunnel
ENABLE_NGROK=0

# ── Telegram Bot (optional) ──────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── OpenAI (optional AI chatbot) ────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Ngrok (optional tunneling) ───────────────────────────────
NGROK_TEAM_TOKEN=your_team_ngrok_token_here
NGROK_PERSONAL_TOKEN=your_personal_ngrok_token_here
