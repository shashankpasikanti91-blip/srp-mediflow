# Environment Variables - SECURE VERSION FOR GITHUB
# Copy this to .env and fill with your real values

# API Keys (Replace with your actual keys)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
OPENAI_API_KEY=your_openai_api_key_here

# N8N Configuration
N8N_BASE_URL=your_n8n_ngrok_url_here
N8N_WEBHOOK_ID=your_webhook_id_here

# Ngrok Tokens (Get from ngrok.com)
NGROK_TEAM_TOKEN=your_team_ngrok_token_here
NGROK_PERSONAL_TOKEN=your_personal_ngrok_token_here

# Hospital Configuration
HOSPITAL_PORT=7500
HOSPITAL_NAME=Star Hospital Kothagudem

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here
