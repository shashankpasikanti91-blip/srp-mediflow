# ══════════════════════════════════════════════════════════════════
#  SRP MediFlow — Environment Variables Template
#  1. Copy this file:  cp .env.example .env
#  2. Fill in every value marked <...>
#  3. NEVER commit .env to git  (it is gitignored)
#  See HETZNER_DEPLOY.md for full production deployment guide.
# ══════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────
PORT=7500
APP_URL=https://mediflow.srpailabs.com
ROOT_DOMAIN=mediflow.srpailabs.com

# ── PostgreSQL — Platform DB (billing, client registry) ───────────
# Hetzner Linux production: PG_PORT=5432
# Local Windows dev:        PG_PORT=5434
PG_HOST=localhost
PG_PORT=5432
PG_DB=srp_platform_db
PG_USER=postgres
PG_PASSWORD=<your_platform_db_password>
PLATFORM_DB_NAME=srp_platform_db

# ── PostgreSQL — Tenant DBs (each hospital) ───────────────────────
TENANT_DB_USER=ats_user
TENANT_DB_PASSWORD=<your_tenant_db_password>

# ── Telegram — Staff Group Alerts ─────────────────────────────────
# 1. Talk to @BotFather → /newbot → save the token
# 2. Add bot to staff group, make it admin
# 3. Get chat ID from: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=<your_bot_token>
TELEGRAM_CHAT_ID=<your_staff_group_chat_id>

# ── Telegram — Founder Personal Alerts ───────────────────────────
# Set FOUNDER_CHAT_ID to your personal Telegram chat ID
# Leave FOUNDER_BOT_TOKEN empty to reuse the same bot
FOUNDER_CHAT_ID=<your_personal_telegram_chat_id>
FOUNDER_BOT_TOKEN=

# ── OpenAI GPT-4o-mini (AI message drafting) ──────────────────────
# Get key from https://platform.openai.com/api-keys
# Leave empty — system falls back to static templates without it
OPENAI_API_KEY=<your_openai_api_key>

# ── WhatsApp Business API (Meta Cloud API) ────────────────────────
# Set up at https://developers.facebook.com/apps/
# Leave all empty to disable — system works fully without WhatsApp
WHATSAPP_API_KEY=<your_whatsapp_bearer_token>
WHATSAPP_PHONE_NUMBER_ID=<your_phone_number_id>
WHATSAPP_WEBHOOK_SECRET=<choose_strong_random_secret>

# ── Ngrok (LOCAL DEV ONLY — do NOT set on production) ─────────────
# Get auth token from https://ngrok.com/ → Your Authtoken
# Leave empty on production servers
NGROK_AUTH_TOKEN=

# ── n8n Workflow Automation (optional) ───────────────────────────
N8N_WEBHOOK_URL=
N8N_API_KEY=
N8N_INSTANCE_URL=
